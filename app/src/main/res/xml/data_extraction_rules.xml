<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude
            domain="sharedpref"
            path="palmclaw_config.xml" />
        <exclude
            domain="sharedpref"
            path="palmclaw_secure_config.xml" />
        <exclude
            domain="database"
            path="palmclaw.db" />
        <exclude
            domain="database"
            path="palmclaw.db-shm" />
        <exclude
            domain="database"
            path="palmclaw.db-wal" />
        <exclude
            domain="file"
            path="palmclaw/" />
    </cloud-backup>
    <device-transfer>
        <exclude
            domain="sharedpref"
            path="palmclaw_config.xml" />
        <exclude
            domain="sharedpref"
            path="palmclaw_secure_config.xml" />
        <exclude
            domain="database"
            path="palmclaw.db" />
        <exclude
            domain="database"
            path="palmclaw.db-shm" />
        <exclude
            domain="database"
            path="palmclaw.db-wal" />
        <exclude
            domain="file"
            path="palmclaw/" />
    </device-transfer>
</data-extraction-rules>
